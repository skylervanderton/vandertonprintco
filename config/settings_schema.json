[
  {
    "name": "theme_info",
    "theme_name": "Vanderton",
    "theme_version": "1.0.0",
    "theme_author": "Vanderton Print Co",
    "theme_documentation_url": "",
    "theme_support_url": ""
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_primary",
        "label": "Primary color",
        "default": "#000000"
      },
      {
        "type": "color",
        "id": "color_background",
        "label": "Page background",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent / sale color",
        "default": "#f94c43"
      },
      {
        "type": "color",
        "id": "color_bg_secondary",
        "label": "Secondary background",
        "default": "#f2f2f2"
      },
      {
        "type": "color",
        "id": "color_footer_bg",
        "label": "Footer background",
        "default": "#f9f9f9"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Border color",
        "default": "#e2e2e2"
      },
      {
        "type": "color",
        "id": "color_text_muted",
        "label": "Muted text color",
        "default": "#6a6a6a"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading font",
        "default": "helvetica_neue_n4"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body font",
        "default": "helvetica_neue_n4"
      },
      {
        "type": "range",
        "id": "type_base_size",
        "label": "Base font size (px)",
        "min": 12,
        "max": 18,
        "step": 1,
        "default": 14
      }
    ]
  },
  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image"
      },
      {
        "type": "range",
        "id": "logo_max_width",
        "label": "Logo max width (px)",
        "min": 80,
        "max": 300,
        "step": 10,
        "default": 180
      }
    ]
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      {
        "type": "text",
        "id": "social_instagram",
        "label": "Instagram username",
        "placeholder": "username"
      },
      {
        "type": "text",
        "id": "social_facebook",
        "label": "Facebook username",
        "placeholder": "username"
      },
      {
        "type": "text",
        "id": "social_pinterest",
        "label": "Pinterest username",
        "placeholder": "username"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart type",
        "options": [
          { "value": "drawer", "label": "Slide-out drawer" },
          { "value": "page", "label": "Cart page" }
        ],
        "default": "drawer"
      },
      {
        "type": "checkbox",
        "id": "enable_cart_notes",
        "label": "Enable cart notes",
        "default": false
      }
    ]
  }
]
