<section
  class="hero hero--{{ section.settings.height }}"
  style="color: {{ section.settings.text_color }};"
>
  <div class="hero__media">
    {%- if section.settings.video != blank -%}
      <video
        autoplay
        muted
        loop
        playsinline
        poster="{{ section.settings.image | image_url: width: 1920 }}"
      >
        <source src="{{ section.settings.video }}">
      </video>
    {%- elsif section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 1920 }}"
        srcset="{{ section.settings.image | image_url: width: 800 }} 800w,
                {{ section.settings.image | image_url: width: 1200 }} 1200w,
                {{ section.settings.image | image_url: width: 1600 }} 1600w,
                {{ section.settings.image | image_url: width: 1920 }} 1920w"
        sizes="100vw"
        alt="{{ section.settings.image.alt | escape }}"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
        loading="eager"
        fetchpriority="high">
    {%- else -%}
      <div style="background-color: var(--color-bg-secondary); width: 100%; height: 100%;"></div>
    {%- endif -%}
  </div>

  {%- if section.settings.overlay_opacity > 0 -%}
    <div
      class="hero__overlay"
      style="background-color: {{ section.settings.overlay_color }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
    ></div>
  {%- endif -%}

  <div class="hero__content hero__content--{{ section.settings.text_alignment }}">
    {%- if section.settings.eyebrow != blank -%}
      <p class="hero__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="hero__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="hero__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <a
        href="{{ section.settings.button_link }}"
        class="btn {% if section.settings.button_style == 'primary' %}btn--primary{% elsif section.settings.button_style == 'outline_white' %}btn--outline-white{% else %}btn--secondary{% endif %}"
      >
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "video",
      "label": "Background video URL (MP4)"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Section height",
      "options": [
        { "value": "full", "label": "Full screen" },
        { "value": "large", "label": "Large (70vh)" },
        { "value": "medium", "label": "Medium (60vh)" },
        { "value": "short", "label": "Short (45vh)" }
      ],
      "default": "large"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity (%)",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 30
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Fine Art Prints That Give Back"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Every purchase supports wildlife conservation."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "primary", "label": "Primary (black)" },
        { "value": "outline_white", "label": "Outline white" },
        { "value": "secondary", "label": "Outline black" }
      ],
      "default": "outline_white"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
