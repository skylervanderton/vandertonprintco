<section
  class="timeline"
  style="background-color: {{ section.settings.bg_color }};"
>
  <div class="container">
    {%- if section.settings.heading != blank or section.settings.eyebrow != blank -%}
      <div class="timeline__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="eyebrow" style="margin-bottom: 12px;">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="h2">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p style="color: var(--color-text-muted); margin-top: 12px; max-width: 520px; margin-left: auto; margin-right: auto;">
            {{ section.settings.subheading }}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ol class="timeline__list">
        {%- for block in section.blocks -%}
          <li class="timeline__item" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <div style="margin-bottom: 20px;">
                <img
                  src="{{ block.settings.image | image_url: width: 80 }}"
                  alt="{{ block.settings.image.alt | escape }}"
                  width="60"
                  height="60"
                  loading="lazy"
                  style="margin: 0 auto; width: 60px; height: 60px; object-fit: contain;">
              </div>
            {%- else -%}
              <div class="timeline__number">{{ forloop.index }}</div>
            {%- endif -%}
            {%- if block.settings.title != blank -%}
              <h3 class="timeline__title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="timeline__text">{{ block.settings.text }}</p>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ol>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Timeline / Process",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#f2f2f2"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Our Process"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon / image (optional)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Step title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Brief description of this step in the process."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Timeline",
      "blocks": [
        { "type": "step", "settings": { "title": "Shot on Film" } },
        { "type": "step", "settings": { "title": "Printed on Premium Paper" } },
        { "type": "step", "settings": { "title": "Hand-Signed" } },
        { "type": "step", "settings": { "title": "Custom Framed" } }
      ]
    }
  ]
}
{% endschema %}
