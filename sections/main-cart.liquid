<div class="container">
  <div class="cart-page">
    <h1 class="cart-page__title">{{ 'cart.title' | t }}</h1>

    {%- if cart.item_count > 0 -%}
      {%- form 'cart', cart, id: 'cart-form', novalidate: 'novalidate' -%}
        <div class="cart-page__layout">
          <div>
            <table class="cart-table">
              <thead>
                <tr>
                  <th colspan="2">{{ 'products.title' | t }}</th>
                  <th>{{ 'products.quantity' | t }}</th>
                  <th style="text-align: right;">{{ 'cart.subtotal' | t }}</th>
                </tr>
              </thead>
              <tbody>
                {%- for item in cart.items -%}
                  <tr class="cart-table__row" data-cart-item data-key="{{ item.key }}">
                    <td style="width: 100px;">
                      <a href="{{ item.url }}">
                        {%- if item.image -%}
                          <img
                            src="{{ item.image | image_url: width: 200 }}"
                            alt="{{ item.image.alt | escape }}"
                            width="90"
                            height="120"
                            loading="lazy"
                            style="display:block;">
                        {%- endif -%}
                      </a>
                    </td>
                    <td>
                      <p style="font-family: var(--font-heading); font-size: 1rem; margin-bottom: 4px;">
                        <a href="{{ item.url }}">{{ item.product.title }}</a>
                      </p>
                      {%- if item.variant.title != 'Default Title' -%}
                        <p style="font-size: 0.85rem; color: var(--color-text-muted);">{{ item.variant.title }}</p>
                      {%- endif -%}
                      {%- if item.line_level_discount_allocations.size > 0 -%}
                        {%- for discount in item.line_level_discount_allocations -%}
                          <p style="font-size: 0.8rem; color: var(--color-accent);">{{ discount.discount_application.title }}</p>
                        {%- endfor -%}
                      {%- endif -%}
                      <button
                        class="cart-item__remove"
                        data-remove-item
                        data-key="{{ item.key }}"
                        style="margin-top: 8px;"
                        type="button"
                        aria-label="{{ 'cart.remove' | t }}: {{ item.title | escape }}"
                      >
                        {{ 'cart.remove' | t }}
                      </button>
                    </td>
                    <td>
                      <div class="cart-item__qty" style="display: inline-flex;">
                        <button
                          type="button"
                          data-qty-minus
                          data-key="{{ item.key }}"
                          aria-label="Decrease quantity"
                        >−</button>
                        <span class="cart-item__qty-num" data-qty-value>{{ item.quantity }}</span>
                        <button
                          type="button"
                          data-qty-plus
                          data-key="{{ item.key }}"
                          aria-label="Increase quantity"
                        >+</button>
                      </div>
                    </td>
                    <td style="text-align: right; font-family: var(--font-display); font-size: 13px; letter-spacing: 0.05em;">
                      {{ item.final_line_price | money }}
                    </td>
                  </tr>
                {%- endfor -%}
              </tbody>
            </table>
          </div>

          <div>
            <div class="cart-summary">
              <h2 class="cart-summary__title">{{ 'cart.subtotal' | t }}</h2>

              {%- if cart.cart_level_discount_applications.size > 0 -%}
                {%- for discount in cart.cart_level_discount_applications -%}
                  <div class="cart-summary__row">
                    <span>{{ discount.title }}</span>
                    <span>-{{ discount.total_allocated_amount | money }}</span>
                  </div>
                {%- endfor -%}
              {%- endif -%}

              <div class="cart-summary__row cart-summary__row--total">
                <span>Total</span>
                <span>{{ cart.total_price | money }}</span>
              </div>

              {%- if settings.enable_cart_notes -%}
                <div style="margin-bottom: 16px;">
                  <label for="cart-note" style="display: block; font-family: var(--font-display); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 8px;">
                    Order notes
                  </label>
                  <textarea
                    id="cart-note"
                    name="note"
                    rows="3"
                    class="newsletter-form__input"
                    style="width: 100%; border: 1px solid var(--color-border); resize: vertical;"
                    placeholder="{{ 'cart.note_placeholder' | t }}"
                  >{{ cart.note }}</textarea>
                </div>
              {%- endif -%}

              <button
                type="submit"
                name="checkout"
                class="btn btn--primary btn--full"
              >
                {{ 'cart.checkout' | t }}
              </button>

              <p class="cart-summary__tax">
                Shipping & taxes calculated at checkout
              </p>
            </div>
          </div>
        </div>
      {%- endform -%}

    {%- else -%}
      <div style="text-align: center; padding: 80px 0;">
        <p style="font-family: var(--font-display); font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-text-muted); margin-bottom: 24px;">
          {{ 'cart.empty' | t }}
        </p>
        <a href="/collections/shop" class="btn btn--primary">{{ 'cart.empty_cta' | t }}</a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Cart",
  "settings": []
}
{% endschema %}
