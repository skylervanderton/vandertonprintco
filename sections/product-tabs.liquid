<section class="product-tabs">
  <div class="container">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="product-tabs__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="eyebrow" style="margin-bottom: 12px;">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="h2">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p style="color: var(--color-text-muted); margin-top: 12px; max-width: 520px; margin-left: auto; margin-right: auto;">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="product-tabs__nav" role="tablist">
        {%- for block in section.blocks -%}
          <button
            class="product-tabs__tab{% if forloop.first %} is-active{% endif %}"
            data-tab="tab-{{ block.id }}"
            role="tab"
            aria-selected="{{ forloop.first }}"
            aria-controls="panel-{{ block.id }}"
            id="tab-btn-{{ block.id }}"
            type="button"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.tab_label }}
          </button>
        {%- endfor -%}
      </div>

      {%- for block in section.blocks -%}
        {%- assign tab_collection = collections[block.settings.collection] -%}
        <div
          class="product-tabs__panel{% if forloop.first %} is-active{% endif %}"
          data-tab="tab-{{ block.id }}"
          id="panel-{{ block.id }}"
          role="tabpanel"
          aria-labelledby="tab-btn-{{ block.id }}"
          {{ block.shopify_attributes }}
        >
          {%- if tab_collection != blank and tab_collection.products.size > 0 -%}
            <div class="grid--products product-grid-container">
              {%- assign products_limit = section.settings.products_per_tab -%}
              {%- for product in tab_collection.products limit: products_limit -%}
                {% render 'product-card', product: product, collection: tab_collection %}
              {%- endfor -%}
            </div>

            {%- if section.settings.show_view_all -%}
              <div style="text-align: center; margin-top: 40px;">
                <a href="{{ tab_collection.url }}" class="btn btn--secondary">
                  View all {{ tab_collection.title }}
                </a>
              </div>
            {%- endif -%}
          {%- else -%}
            <p style="text-align: center; color: var(--color-text-muted); padding: 60px 0;">
              No products found in this collection.
            </p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Product tabs",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Shop by Collection"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "range",
      "id": "products_per_tab",
      "label": "Products per tab",
      "min": 4,
      "max": 20,
      "step": 4,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show \"View all\" button",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "text",
          "id": "tab_label",
          "label": "Tab label",
          "default": "Collection"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product tabs",
      "blocks": [
        { "type": "tab", "settings": { "tab_label": "Series" } },
        { "type": "tab", "settings": { "tab_label": "Animals" } },
        { "type": "tab", "settings": { "tab_label": "Format" } }
      ]
    }
  ]
}
{% endschema %}
