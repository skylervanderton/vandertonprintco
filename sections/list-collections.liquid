<div class="list-collections">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h1 class="list-collections__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}

    <div class="list-collections__grid list-collections__grid--{{ section.settings.columns }}col">
      {%- for collection in collections -%}
        {%- unless collection.handle == 'frontpage' -%}
          <a href="{{ collection.url }}" class="collection-card">
            <div class="collection-card__image-wrapper">
              {%- if collection.image -%}
                <img
                  class="collection-card__image"
                  src="{{ collection.image | image_url: width: 800 }}"
                  alt="{{ collection.image.alt | default: collection.title | escape }}"
                  width="{{ collection.image.width }}"
                  height="{{ collection.image.height }}"
                  loading="lazy">
              {%- elsif collection.products.first.featured_media -%}
                <img
                  class="collection-card__image"
                  src="{{ collection.products.first.featured_media | image_url: width: 800 }}"
                  alt="{{ collection.title | escape }}"
                  loading="lazy">
              {%- else -%}
                <div class="collection-card__placeholder"></div>
              {%- endif -%}
              <div class="collection-card__overlay"></div>
              <div class="collection-card__content">
                <h2 class="collection-card__title">{{ collection.title }}</h2>
                {%- if collection.products_count > 0 -%}
                  <p class="collection-card__count">{{ collection.products_count }} {{ collection.products_count | pluralize: 'print', 'prints' }}</p>
                {%- endif -%}
              </div>
            </div>
          </a>
        {%- endunless -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
.list-collections {
  padding: 60px 0 80px;
}

.list-collections__heading {
  font-family: var(--font-heading);
  font-size: clamp(2rem, 4vw, 3.5rem);
  font-weight: 400;
  letter-spacing: -0.01em;
  text-align: center;
  margin-bottom: 48px;
}

.list-collections__grid {
  display: grid;
  gap: 20px;
}

.list-collections__grid--2col { grid-template-columns: repeat(2, 1fr); }
.list-collections__grid--3col { grid-template-columns: repeat(3, 1fr); }
.list-collections__grid--4col { grid-template-columns: repeat(4, 1fr); }

.collection-card {
  display: block;
  text-decoration: none;
  color: #fff;
}

.collection-card__image-wrapper {
  position: relative;
  overflow: hidden;
  aspect-ratio: 3 / 4;
  background-color: #1a1a1a;
}

.collection-card__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.collection-card:hover .collection-card__image {
  transform: scale(1.06);
}

.collection-card__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.15) 50%, rgba(0,0,0,0.05) 100%);
  transition: background 0.3s ease;
}

.collection-card:hover .collection-card__overlay {
  background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.25) 50%, rgba(0,0,0,0.1) 100%);
}

.collection-card__content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 28px 24px;
}

.collection-card__title {
  font-family: var(--font-heading);
  font-size: clamp(1.1rem, 2vw, 1.5rem);
  font-weight: 400;
  color: #ffffff;
  line-height: 1.2;
  margin-bottom: 4px;
}

.collection-card__count {
  font-family: var(--font-display);
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.7);
  margin-top: 6px;
}

@media (max-width: 768px) {
  .list-collections__grid--3col,
  .list-collections__grid--4col {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 480px) {
  .list-collections__grid {
    grid-template-columns: 1fr;
  }
}
</style>

{% schema %}
{
  "name": "Collections list",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Collections"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns (desktop)",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    }
  ]
}
{% endschema %}
