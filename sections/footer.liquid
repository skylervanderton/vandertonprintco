<footer class="site-footer" style="background-color: {{ section.settings.bg_color }};">
  <div class="container">
    <div class="site-footer__main">

      {%- comment -%} Brand Column {%- endcomment -%}
      <div class="site-footer__brand">
        {%- if settings.logo -%}
          <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
            <img src="{{ settings.logo | image_url: width: 150 }}" alt="{{ shop.name }}" width="150" height="auto" loading="lazy">
          </a>
        {%- else -%}
          <a href="{{ routes.root_url }}" class="site-header__logo-text">{{ shop.name }}</a>
        {%- endif -%}

        {%- if section.settings.brand_tagline != blank -%}
          <p class="site-footer__tagline">{{ section.settings.brand_tagline }}</p>
        {%- endif -%}

        <div class="site-footer__social">
          {%- if settings.social_instagram != blank -%}
            <a href="https://instagram.com/{{ settings.social_instagram }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
              {% render 'icon-instagram' %}
            </a>
          {%- endif -%}
          {%- if settings.social_facebook != blank -%}
            <a href="https://facebook.com/{{ settings.social_facebook }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
              {% render 'icon-facebook' %}
            </a>
          {%- endif -%}
          {%- if settings.social_pinterest != blank -%}
            <a href="https://pinterest.com/{{ settings.social_pinterest }}" target="_blank" rel="noopener noreferrer" aria-label="Pinterest">
              {% render 'icon-pinterest' %}
            </a>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Shop Column — always shown {%- endcomment -%}
      <div class="site-footer__col">
        <h3 class="site-footer__col-heading">Shop</h3>
        <ul>
          <li><a href="{{ routes.collections_url }}">Collections</a></li>
          <li><a href="/collections/all">All Prints</a></li>
        </ul>
      </div>

      {%- comment -%} Nav Columns {%- endcomment -%}
      {%- for i in (1..3) -%}
        {%- liquid
          assign menu_key = 'footer_menu_' | append: i
          assign heading_key = 'footer_heading_' | append: i
          assign menu_handle = section.settings[menu_key]
          assign menu_heading = section.settings[heading_key]
        -%}
        {%- if menu_handle != blank and linklists[menu_handle].links.size > 0 -%}
          <div class="site-footer__col">
            {%- if menu_heading != blank -%}
              <h3 class="site-footer__col-heading">{{ menu_heading }}</h3>
            {%- endif -%}
            <ul>
              {%- for link in linklists[menu_handle].links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}

    </div>

    {%- comment -%} Bottom bar {%- endcomment -%}
    <div class="site-footer__bottom">
      <p class="site-footer__copyright">
        © {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
      </p>
      {%- if section.settings.footer_menu != blank and linklists[section.settings.footer_menu].links.size > 0 -%}
        <nav aria-label="Footer legal">
          <ul style="display: flex; gap: 20px; flex-wrap: wrap;">
            {%- for link in linklists[section.settings.footer_menu].links -%}
              <li>
                <a href="{{ link.url }}" style="font-size: 0.8rem; color: var(--color-text-muted);">
                  {{ link.title }}
                </a>
              </li>
            {%- endfor -%}
          </ul>
        </nav>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#f9f9f9"
    },
    {
      "type": "text",
      "id": "brand_tagline",
      "label": "Brand tagline",
      "default": "Fine art prints for those who care about our planet."
    },
    {
      "type": "header",
      "content": "Navigation columns"
    },
    {
      "type": "text",
      "id": "footer_heading_1",
      "label": "Column 1 heading",
      "default": "About"
    },
    {
      "type": "link_list",
      "id": "footer_menu_1",
      "label": "Column 1 menu",
      "default": "footer"
    },
    {
      "type": "text",
      "id": "footer_heading_2",
      "label": "Column 2 heading",
      "default": "Shop"
    },
    {
      "type": "link_list",
      "id": "footer_menu_2",
      "label": "Column 2 menu"
    },
    {
      "type": "text",
      "id": "footer_heading_3",
      "label": "Column 3 heading",
      "default": "Help"
    },
    {
      "type": "link_list",
      "id": "footer_menu_3",
      "label": "Column 3 menu"
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Legal links menu"
    }
  ]
}
{% endschema %}
