<section
  class="newsletter-section"
  style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};"
>
  <div class="container">
    <div class="newsletter-section__inner">
      {%- if section.settings.eyebrow != blank -%}
        <p class="newsletter-section__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="newsletter-section__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <p class="newsletter-section__text">{{ section.settings.text }}</p>
      {%- endif -%}

      {%- if section.settings.embed_code != blank -%}
        {%- comment -%} Third-party embed (Klaviyo, Flodesk, etc.) {%- endcomment -%}
        <div class="newsletter-embed">
          {{ section.settings.embed_code }}
        </div>
      {%- else -%}
        {%- assign newsletter_form_id = 'newsletter-form-' | append: section.id -%}
        {%- form 'customer', id: newsletter_form_id -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="newsletter-form">
            <label for="newsletter-email-{{ section.id }}" class="visually-hidden">
              {{ 'forms.email' | t }}
            </label>
            <input
              class="newsletter-form__input"
              type="email"
              name="contact[email]"
              id="newsletter-email-{{ section.id }}"
              value="{{ customer.email }}"
              aria-required="true"
              autocomplete="email"
              placeholder="{{ 'forms.email_placeholder' | t }}"
              required
            >
            <button class="btn btn--primary newsletter-form__button" type="submit">
              {{ section.settings.button_label | default: 'Subscribe' }}
            </button>
          </div>

          {%- if form.posted_successfully? -%}
            <p class="newsletter-form__success" role="status" style="margin-top: 12px; font-size: 0.85rem; color: #27ae60;">
              {{ 'forms.success' | t }}
            </p>
          {%- endif -%}
          {%- if form.errors -%}
            <p class="newsletter-form__error" role="alert" style="margin-top: 12px; font-size: 0.85rem; color: var(--color-accent);">
              {{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}
            </p>
          {%- endif -%}
        {%- endform -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Stay Connected"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join the Journey"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Subtext",
      "default": "Stay up to date with new collections and conservation stories."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "html",
      "id": "embed_code",
      "label": "Third-party form embed code (Klaviyo, Flodesk, etc.)"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
