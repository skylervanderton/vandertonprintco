{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_media = product.media
-%}

<div class="container">
  {% render 'breadcrumb' %}

  <div class="product-layout">
    {%- comment -%} Product Gallery {%- endcomment -%}
    <div class="product-gallery">
      <div class="product-gallery__main">
        {%- if product_media.size > 0 -%}
          <img
            id="product-gallery-main"
            src="{{ product_media[0] | image_url: width: 900 }}"
            alt="{{ product_media[0].alt | escape }}"
            width="{{ product_media[0].preview_image.width }}"
            height="{{ product_media[0].preview_image.height }}"
            loading="eager"
            fetchpriority="high">
        {%- else -%}
          <img src="{{ 'product-placeholder.svg' | asset_url }}" alt="{{ product.title | escape }}">
        {%- endif -%}
      </div>

      {%- if product_media.size > 1 -%}
        <div class="product-gallery__thumbs">
          {%- for media in product_media limit: 5 -%}
            <button
              class="product-gallery__thumb{% if forloop.first %} is-active{% endif %}"
              data-src="{{ media | image_url: width: 900 }}"
              data-alt="{{ media.alt | escape }}"
              type="button"
              aria-label="{{ media.alt | default: product.title | escape }}"
            >
              <img
                src="{{ media | image_url: width: 120 }}"
                alt="{{ media.alt | escape }}"
                width="120"
                height="120"
                loading="lazy">
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Product Info {%- endcomment -%}
    <div class="product-info">
      {%- if product.vendor -%}
        <p class="product-info__vendor">{{ product.vendor }}</p>
      {%- endif -%}

      <h1 class="product-info__title">{{ product.title }}</h1>

      {%- comment -%} Species metadata (from product metafields or tags) {%- endcomment -%}
      {%- assign species_tag = product.tags | join: ',' -%}
      {%- if product.metafields.custom.species != blank or product.metafields.custom.endangered_level != blank -%}
        <div class="product-info__species">
          {%- if product.metafields.custom.species != blank -%}
            <div class="product-info__species-item">
              <span class="product-info__species-label">{{ 'products.species' | t }}</span>
              <span class="product-info__species-value">{{ product.metafields.custom.species }}</span>
            </div>
          {%- endif -%}
          {%- if product.metafields.custom.endangered_level != blank -%}
            <div class="product-info__species-item">
              <span class="product-info__species-label">{{ 'products.endangered_level' | t }}</span>
              <span class="product-info__species-value">{{ product.metafields.custom.endangered_level }}</span>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- comment -%} Price {%- endcomment -%}
      <div class="product-info__price">
        <span id="product-price">
          {%- if product.price_varies -%}
            {{ 'products.from_price' | t: price: product.price_min | money }}
          {%- else -%}
            {{ current_variant.price | money }}
          {%- endif -%}
        </span>
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <span style="text-decoration: line-through; color: var(--color-text-muted); font-size: 0.85em; margin-left: 8px;">
            {{ current_variant.compare_at_price | money }}
          </span>
        {%- endif -%}
      </div>

      {%- comment -%} Product Form {%- endcomment -%}
      {%- form 'product', product, id: 'product-form', class: 'product-form', novalidate: 'novalidate' -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}" id="variant-id">

        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <div class="product-form__option">
              <div class="product-form__option-label">
                <span>{{ option.name }}</span>
                <span class="product-form__option-selected" id="option-selected-{{ forloop.index }}">
                  {{ option.selected_value }}
                </span>
              </div>
              <div class="product-form__variants" role="group" aria-label="{{ option.name }}">
                {%- for value in option.values -%}
                  <button
                    class="variant-btn{% if option.selected_value == value %} is-active{% endif %}"
                    data-option-index="{{ forloop.parentloop.index0 }}"
                    data-value="{{ value | escape }}"
                    type="button"
                    aria-pressed="{% if option.selected_value == value %}true{% else %}false{% endif %}"
                  >
                    {{ value }}
                  </button>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        {%- endunless -%}

        {%- comment -%} Hidden variants data for JS {%- endcomment -%}
        <script type="application/json" id="product-variants-data">
          {{ product.variants | json }}
        </script>

        <div class="product-form__atc">
          <button
            type="submit"
            name="add"
            class="btn btn--primary btn--full"
            id="product-add-to-cart"
            {%- unless current_variant.available -%}disabled{%- endunless -%}
          >
            {%- if current_variant.available -%}
              {{ 'cart.add_to_cart' | t }}
            {%- else -%}
              {{ 'products.sold_out' | t }}
            {%- endif -%}
          </button>
        </div>
      {%- endform -%}

      {%- if product.description != blank -%}
        <div class="product-info__description rte">
          {{ product.description }}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

<script>
  (function() {
    const variantsEl = document.getElementById('product-variants-data');
    if (!variantsEl) return;

    const variants = JSON.parse(variantsEl.textContent.trim());
    const form = document.getElementById('product-form');
    const variantInput = document.getElementById('variant-id');
    const priceEl = document.getElementById('product-price');
    const addToCartBtn = document.getElementById('product-add-to-cart');
    const mainImage = document.getElementById('product-gallery-main');
    const thumbBtns = document.querySelectorAll('.product-gallery__thumb');

    // Track selected options
    const selectedOptions = {};
    document.querySelectorAll('.variant-btn.is-active').forEach(btn => {
      const idx = btn.dataset.optionIndex;
      selectedOptions[idx] = btn.dataset.value;
    });

    function findVariant() {
      return variants.find(v =>
        v.options.every((opt, i) => selectedOptions[i] === opt)
      );
    }

    function updateGallery(variant) {
      if (!variant || !variant.featured_image || !mainImage) return;
      const img = variant.featured_image;
      // Swap main image src — use Shopify CDN sizing
      const newSrc = img.src.replace(/(\.[^.]+)$/, '_900x$1').replace('https:', '');
      mainImage.src = img.src;
      mainImage.alt = img.alt || mainImage.alt;

      // Highlight matching thumb
      thumbBtns.forEach(btn => {
        const thumbSrc = btn.querySelector('img')?.src || '';
        const variantSrc = img.src || '';
        // Match by common filename segment
        const fileName = variantSrc.split('/').pop().split('?')[0].split('.')[0];
        if (thumbSrc.includes(fileName)) {
          btn.classList.add('is-active');
        } else {
          btn.classList.remove('is-active');
        }
      });
    }

    function updateVariant() {
      const variant = findVariant();
      if (!variant) return;

      variantInput.value = variant.id;

      // Update price
      if (priceEl) {
        const price = (variant.price / 100).toFixed(2);
        priceEl.textContent = '$' + price;
      }

      // Update add to cart button
      if (addToCartBtn) {
        if (variant.available) {
          addToCartBtn.disabled = false;
          addToCartBtn.textContent = 'Add to Cart';
        } else {
          addToCartBtn.disabled = true;
          addToCartBtn.textContent = 'Sold Out';
        }
      }

      updateGallery(variant);
    }

    // Handle variant button clicks
    document.querySelectorAll('.variant-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        const idx = this.dataset.optionIndex;
        const val = this.dataset.value;

        // Update active state within this option group
        document.querySelectorAll(`.variant-btn[data-option-index="${idx}"]`).forEach(b => {
          b.classList.remove('is-active');
          b.setAttribute('aria-pressed', 'false');
        });
        this.classList.add('is-active');
        this.setAttribute('aria-pressed', 'true');

        // Update selected option label
        const labelEl = document.getElementById('option-selected-' + (parseInt(idx) + 1));
        if (labelEl) labelEl.textContent = val;

        selectedOptions[idx] = val;
        updateVariant();
      });
    });

    // Thumb click handler
    thumbBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        if (!mainImage) return;
        mainImage.src = this.dataset.src;
        mainImage.alt = this.dataset.alt;
        thumbBtns.forEach(b => b.classList.remove('is-active'));
        this.classList.add('is-active');
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Product information",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_share_buttons",
      "label": "Show share buttons",
      "default": false
    }
  ]
}
{% endschema %}
