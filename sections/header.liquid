<header
  class="site-header"
  data-header
  style="{% unless section.settings.header_border_bottom %}border-bottom: none;{% endunless %}"
>
  <div class="site-header__inner container--wide">

    {%- comment -%} Logo — centered above nav {%- endcomment -%}
    <div class="site-header__top">
      <a class="site-header__logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        {%- if section.settings.logo -%}
          <img
            src="{{ section.settings.logo | image_url: width: section.settings.logo_max_width }}"
            alt="{{ shop.name }}"
            width="{{ section.settings.logo_max_width }}"
            height="auto"
            loading="eager">
        {%- else -%}
          <span class="site-header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      {%- comment -%} Utility Icons — top right {%- endcomment -%}
      <div class="site-header__icons">
        <button
          class="site-header__icon"
          data-open-search
          aria-label="{{ 'accessibility.open_search' | t }}"
          type="button"
        >
          {% render 'icon-search' %}
        </button>

        <a
          class="site-header__icon site-header__icon--account"
          href="{{ routes.account_url }}"
          aria-label="{{ 'accessibility.view_account' | t }}"
        >
          {% render 'icon-account' %}
        </a>

        <button
          class="site-header__icon site-header__cart"
          data-open-cart
          aria-label="{{ 'accessibility.open_cart' | t }} ({{ cart.item_count }})"
          type="button"
        >
          {% render 'icon-cart' %}
          <span class="cart-count" {% if cart.item_count == 0 %}style="display:none"{% endif %} aria-hidden="true">
            {{ cart.item_count }}
          </span>
        </button>

        <button
          class="site-header__icon site-header__hamburger"
          data-open-mobile-menu
          aria-label="{{ 'accessibility.open_menu' | t }}"
          aria-expanded="false"
          aria-controls="mobile-menu"
          type="button"
        >
          {% render 'icon-hamburger' %}
        </button>
      </div>
    </div>

    {%- comment -%} Desktop Navigation — below logo {%- endcomment -%}
    <nav class="site-nav" aria-label="Primary navigation" role="navigation">
      <ul class="site-nav__list" role="list">
        {%- for link in linklists[section.settings.main_menu].links -%}
          <li class="site-nav__item{% if link.links.size > 0 %} site-nav__item--has-dropdown{% endif %}" role="none">
            <a
              class="site-nav__link{% if link.active %} site-nav__link--active{% endif %}"
              href="{{ link.url }}"
              {%- if link.links.size > 0 -%}
                aria-haspopup="true"
                aria-expanded="false"
              {%- endif -%}
              role="menuitem"
            >
              {{- link.title -}}
              {%- if link.links.size > 0 -%}
                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin-left:4px; vertical-align:middle;"><polyline points="6 9 12 15 18 9"/></svg>
              {%- endif -%}
            </a>

            {%- if link.links.size > 0 -%}
              <div class="site-nav__dropdown" role="menu">
                <ul class="site-nav__dropdown-list" role="list">
                  {%- for child_link in link.links -%}
                    <li role="none">
                      <a href="{{ child_link.url }}" role="menuitem"
                        {% if child_link.active %}aria-current="page"{% endif %}>
                        {{- child_link.title -}}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              </div>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </nav>

  </div>
</header>

{%- comment -%} Mobile Menu {%- endcomment -%}
<div
  class="mobile-menu"
  id="mobile-menu"
  data-mobile-menu
  aria-hidden="true"
  role="dialog"
  aria-label="Navigation menu"
>
  <div class="mobile-menu__header">
    <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
      {%- if section.settings.logo -%}
        <img src="{{ section.settings.logo | image_url: width: 140 }}" alt="{{ shop.name }}" width="140" height="auto">
      {%- else -%}
        <span class="site-header__logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </a>
    <button
      class="mobile-menu__close"
      data-close-mobile-menu
      aria-label="{{ 'accessibility.close_menu' | t }}"
      type="button"
    >
      {% render 'icon-close' %}
    </button>
  </div>

  <nav class="mobile-menu__nav" aria-label="Mobile navigation">
    <ul class="mobile-menu__list" role="list">
      {%- for link in linklists[section.settings.main_menu].links -%}
        <li class="mobile-menu__item">
          {%- if link.links.size > 0 -%}
            <button
              class="mobile-menu__link"
              data-mobile-submenu-toggle
              aria-expanded="false"
              type="button"
            >
              {{ link.title }}
              {% render 'icon-arrow' %}
            </button>
            <div class="mobile-menu__submenu">
              {%- for child_link in link.links -%}
                <a href="{{ child_link.url }}" {% if child_link.active %}aria-current="page"{% endif %}>
                  {{ child_link.title }}
                </a>
              {%- endfor -%}
            </div>
          {%- else -%}
            <a
              class="mobile-menu__link"
              href="{{ link.url }}"
              {% if link.active %}aria-current="page"{% endif %}
            >
              {{ link.title }}
            </a>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>

    <div style="margin-top: 32px; display: flex; flex-direction: column; gap: 12px;">
      <a href="{{ routes.account_url }}" class="btn btn--secondary btn--full">Account</a>
    </div>
  </nav>
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_max_width",
      "label": "Logo max width (px)",
      "min": 80,
      "max": 300,
      "step": 10,
      "default": 180
    },
    {
      "type": "link_list",
      "id": "main_menu",
      "label": "Main menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "sticky_header",
      "label": "Sticky header",
      "default": true
    },
    {
      "type": "color",
      "id": "header_bg_color",
      "label": "Header background",
      "default": "#000000"
    },
    {
      "type": "checkbox",
      "id": "header_border_bottom",
      "label": "Show bottom border",
      "default": true
    }
  ]
}
{% endschema %}
