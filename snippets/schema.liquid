{%- comment -%}
  JSON-LD Schema Markup — Vanderton Print Co.
  Outputs structured data for Google Rich Results.
  Included at the bottom of layout/theme.liquid before </body>:
    {%- render 'schema' -%}

  Page-type schemas: Organization, Product, CollectionPage, Article, FAQPage
  Breadcrumb schema is output on all pages except homepage.
{%- endcomment -%}

{%- comment -%} ======= ORGANIZATION — Homepage ======= {%- endcomment -%}
{%- if template.name == 'index' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Vanderton Print Company",
  "alternateName": "Vanderton Print Co.",
  "url": "{{ shop.url }}",
  "logo": {%- if settings.logo -%}"https:{{ settings.logo | image_url: width: 400 }}"{%- else -%}"{{ shop.url }}/assets/logo.png"{%- endif -%},
  "description": "Vanderton Print Co. is a luxury fine art photo print shop specializing in nature photography prints — landscapes, animals, botanicals, and water scenes — printed on archival Hahnemühle Torchon Paper and shipped nationwide across the US.",
  "areaServed": "US",
  "sameAs": [
    {%- assign social_urls = '' -%}
    {%- if settings.social_instagram != blank -%}
      {%- assign social_urls = social_urls | append: '"https://www.instagram.com/' | append: settings.social_instagram | append: '",' -%}
    {%- endif -%}
    {%- if settings.social_facebook != blank -%}
      {%- assign social_urls = social_urls | append: '"https://www.facebook.com/' | append: settings.social_facebook | append: '",' -%}
    {%- endif -%}
    {%- if settings.social_pinterest != blank -%}
      {%- assign social_urls = social_urls | append: '"https://www.pinterest.com/' | append: settings.social_pinterest | append: '"' -%}
    {%- endif -%}
    {{ social_urls | remove_last: ',' }}
  ]
}
</script>
{%- endif -%}

{%- comment -%} ======= PRODUCT — Product pages ======= {%- endcomment -%}
{%- if template.name == 'product' -%}
  {%- assign current_variant = product.selected_or_first_available_variant -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | default: product.title | append: ' — a fine art nature print from Vanderton Print Co., printed on archival Hahnemühle Torchon Paper.' | json }},
  "image": [
    {%- for media in product.media limit: 5 -%}
      "https:{{ media | image_url: width: 1200 }}"{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ],
  "sku": {{ current_variant.sku | default: current_variant.id | json }},
  "brand": {
    "@type": "Brand",
    "name": "Vanderton Print Co."
  },
  "offers": {
    "@type": "Offer",
    "url": "{{ shop.url }}{{ product.url }}",
    "priceCurrency": "USD",
    "price": "{{ current_variant.price | money_without_currency }}",
    "availability": "{% if current_variant.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
    "itemCondition": "https://schema.org/NewCondition",
    "seller": {
      "@type": "Organization",
      "name": "Vanderton Print Co."
    }
  }
}
</script>
{%- endif -%}

{%- comment -%} ======= COLLECTION PAGE ======= {%- endcomment -%}
{%- if template.name == 'collection' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": {{ collection.title | json }},
  "description": {{ collection.description | strip_html | default: collection.title | append: ' fine art nature prints from Vanderton Print Co. — archival photo prints on Hahnemühle Torchon Paper, shipped nationwide.' | json }},
  "url": "{{ shop.url }}{{ collection.url }}"
}
</script>
{%- endif -%}

{%- comment -%} ======= ARTICLE — Blog posts ======= {%- endcomment -%}
{%- if template.name == 'article' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ article.title | json }},
  "author": {
    "@type": "Person",
    "name": {{ article.author | json }}
  },
  "datePublished": "{{ article.published_at | date: '%Y-%m-%dT%H:%M:%SZ' }}",
  "dateModified": "{{ article.published_at | date: '%Y-%m-%dT%H:%M:%SZ' }}",
  "image": {%- if article.image -%}"https:{{ article.image | image_url: width: 1200 }}"{%- else -%}""{%- endif -%},
  "publisher": {
    "@type": "Organization",
    "name": "Vanderton Print Co.",
    "logo": {
      "@type": "ImageObject",
      "url": {%- if settings.logo -%}"https:{{ settings.logo | image_url: width: 400 }}"{%- else -%}"{{ shop.url }}/assets/logo.png"{%- endif -%}
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ shop.url }}{{ article.url }}"
  }
}
</script>
{%- endif -%}

{%- comment -%} ======= FAQ PAGE ======= {%- endcomment -%}
{%- if template.name == 'page' and template.suffix == 'faq' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What paper do you print on?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We print exclusively on Hahnemühle Torchon Paper, a museum-quality archival fine art paper with a distinctive textured surface. It is acid-free and designed to last for generations."
      }
    },
    {
      "@type": "Question",
      "name": "Who fulfills your prints?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our prints are fulfilled by White House Custom Colour (WHCC), one of the most respected professional print labs in the United States."
      }
    },
    {
      "@type": "Question",
      "name": "Do you offer digital downloads?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. We offer physical fine art prints only — no digital files or downloads."
      }
    },
    {
      "@type": "Question",
      "name": "Do you ship nationwide?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. We ship to all 50 states."
      }
    },
    {
      "@type": "Question",
      "name": "Can I order prints for my business or commercial space?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. We work with business owners looking to add fine art nature prints to their spaces. Contact us for volume or commercial inquiries."
      }
    },
    {
      "@type": "Question",
      "name": "What sizes do you offer?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We offer a range of sizes from 8×10 through 30×40. Available sizes vary by image — see individual product pages for options."
      }
    },
    {
      "@type": "Question",
      "name": "Do you offer framed prints?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Many of our prints are available as framed prints, ready to hang."
      }
    }
  ]
}
</script>
{%- endif -%}

{%- comment -%} ======= BREADCRUMB LIST — all pages except homepage ======= {%- endcomment -%}
{%- unless template.name == 'index' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "{{ shop.url }}"
    }
    {%- if template.name == 'collection' -%}
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": {{ collection.title | json }},
      "item": "{{ shop.url }}{{ collection.url }}"
    }
    {%- elsif template.name == 'product' -%}
      {%- if collection -%}
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": {{ collection.title | json }},
      "item": "{{ shop.url }}{{ collection.url }}"
    }
    ,{
      "@type": "ListItem",
      "position": 3,
      "name": {{ product.title | json }},
      "item": "{{ shop.url }}{{ product.url }}"
    }
      {%- else -%}
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": {{ product.title | json }},
      "item": "{{ shop.url }}{{ product.url }}"
    }
      {%- endif -%}
    {%- elsif template.name == 'page' -%}
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": {{ page.title | json }},
      "item": "{{ shop.url }}{{ page.url }}"
    }
    {%- elsif template.name == 'blog' -%}
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": {{ blog.title | json }},
      "item": "{{ shop.url }}{{ blog.url }}"
    }
    {%- elsif template.name == 'article' -%}
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": {{ blog.title | json }},
      "item": "{{ shop.url }}{{ blog.url }}"
    }
    ,{
      "@type": "ListItem",
      "position": 3,
      "name": {{ article.title | json }},
      "item": "{{ shop.url }}{{ article.url }}"
    }
    {%- endif -%}
  ]
}
</script>
{%- endunless -%}
